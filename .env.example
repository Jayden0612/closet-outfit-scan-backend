# Copy to `.env` (never commit `.env`). Rotate keys if exposed.
OPENAI_API_KEY=

# Optional model override (default: gpt-4o)
# OUTFIT_SCAN_MODEL=gpt-4o

# CORS: comma-separated origins, or * for local dev only
# CORS_ORIGINS=https://yourapp.example

# Rate limits (slowapi format, e.g. 60/minute)
# RATE_LIMIT_IP=60/minute
# RATE_LIMIT_USER=120/minute

# Max image upload size in bytes (default 12 MiB)
# MAX_UPLOAD_BYTES=12582912

# Subscription verification (POST /verify-subscription)
# SKIP_APPLE_VERIFICATION=1
# APP_STORE_ISSUER_ID=
# APP_STORE_KEY_ID=
# APP_STORE_PRIVATE_KEY=
